{
    "version": 2,
    "buildCommand": "cd frontend && npm install && npm run build",
    "devCommand": "npm run dev",
    "builds": [
        {
            "src": "frontend/build",
            "use": "@vercel/static"
        },
        {
            "src": "backend/src/server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": "backend/**"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/src/server.js",
            "methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE",
                "PATCH"
            ]
        },
        {
            "src": "/(.*)",
            "dest": "/index.html",
            "status": 200
        }
    ]
}